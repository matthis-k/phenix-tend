{
  "version": 2,
  "profiles": {
    "git-hook": {
      "phase": "verify",
      "selection": "staged",
      "tasks": [
        "rustfmt-check",
        "nixfmt-check",
        "statix-check",
        "deadnix-check"
      ],
      "contexts": ["local"]
    },
    "manual": {
      "phase": "verify",
      "selection": "changed",
      "tasks": [
        "rustfmt-check",
        "cargo-check",
        "cargo-clippy",
        "cargo-test",
        "nixfmt-check",
        "statix-check",
        "deadnix-check"
      ],
      "contexts": ["local"]
    },
    "full": {
      "phase": "verify",
      "selection": "full",
      "tasks": [
        "rustfmt-check",
        "cargo-check",
        "cargo-clippy",
        "cargo-test",
        "nixfmt-check",
        "statix-check",
        "deadnix-check"
      ],
      "contexts": ["local", "nix-sandbox"]
    },
    "pre-push": {
      "phase": "verify",
      "selection": "full",
      "tasks": ["nix-flake-check"],
      "contexts": ["local"]
    },
    "ci": {
      "phase": "verify",
      "selection": "git-range",
      "tasks": [
        "rustfmt-check",
        "cargo-check",
        "cargo-clippy",
        "cargo-test",
        "nixfmt-check",
        "statix-check",
        "deadnix-check",
        "nix-flake-check"
      ],
      "contexts": ["ci"]
    },
    "fix": {
      "phase": "fix",
      "selection": "staged",
      "tasks": ["rustfmt-fix", "statix-fix", "nixfmt-fix"],
      "contexts": ["local"]
    }
  },
  "contexts": {
    "local": {
      "implementation": "local",
      "allow_mutation": true,
      "allow_interactive": false,
      "allow_network": true,
      "require_sandbox_safe": false
    },
    "ci": {
      "implementation": "local",
      "allow_mutation": false,
      "allow_interactive": false,
      "allow_network": true,
      "require_sandbox_safe": false
    },
    "nix-sandbox": {
      "implementation": "sandbox",
      "allow_mutation": false,
      "allow_interactive": false,
      "allow_network": false,
      "require_sandbox_safe": true
    }
  },
  "node": {
    "id": "phenix-tend",
    "description": "Verify the phenix-tend workspace",
    "tasks": [
      {
        "id": "rustfmt-check",
        "description": "Check Rust formatting",
        "phase": "verify",
        "when": {
          "changed": {
            "paths": ["crates/**/*.rs"]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": ["tend-rustfmt-check"],
            "file_args": "matched",
            "sandbox_safe": true
          }
        }
      },
      {
        "id": "cargo-check",
        "description": "Check that the workspace compiles cleanly",
        "phase": "verify",
        "when": {
          "changed": {
            "paths": ["Cargo.toml", "Cargo.lock", "crates/**/*.rs"]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": ["cargo", "check", "--quiet", "--workspace", "--all-targets"],
            "sandbox_safe": true
          }
        }
      },
      {
        "id": "cargo-clippy",
        "description": "Run Clippy with denied warnings",
        "phase": "verify",
        "when": {
          "changed": {
            "paths": ["Cargo.toml", "Cargo.lock", "crates/**/*.rs"]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": [
              "cargo",
              "clippy",
              "--quiet",
              "--workspace",
              "--all-targets",
              "--",
              "-D",
              "warnings"
            ],
            "sandbox_safe": true
          }
        }
      },
      {
        "id": "cargo-test",
        "description": "Run Rust tests",
        "phase": "verify",
        "when": {
          "changed": {
            "paths": ["Cargo.toml", "Cargo.lock", "crates/**/*.rs"]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": ["cargo", "test", "--workspace"],
            "sandbox_safe": true
          }
        }
      },
      {
        "id": "nixfmt-check",
        "description": "Check Nix formatting",
        "phase": "verify",
        "when": {
          "changed": {
            "paths": ["*.nix", "modules/**/*.nix"]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": ["tend-nixfmt-check"],
            "file_args": "matched",
            "sandbox_safe": true
          }
        }
      },
      {
        "id": "statix-check",
        "description": "Lint Nix files with Statix",
        "phase": "verify",
        "when": {
          "changed": {
            "paths": ["*.nix", "modules/**/*.nix"]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": ["statix", "check"],
            "sandbox_safe": true
          }
        }
      },
      {
        "id": "deadnix-check",
        "description": "Find dead Nix code",
        "phase": "verify",
        "when": {
          "changed": {
            "paths": ["*.nix", "modules/**/*.nix"]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": [
              "deadnix",
              "--fail",
              "--no-lambda-arg",
              "--no-lambda-pattern-names"
            ],
            "sandbox_safe": true
          }
        }
      },
      {
        "id": "nix-flake-check",
        "description": "Run the complete Nix flake gate",
        "phase": "verify",
        "always": true,
        "implementations": {
          "local": {
            "kind": "command",
            "command": ["nix", "flake", "check", "--print-build-logs", "--keep-going"],
            "network": true,
            "sandbox_safe": false
          }
        }
      },
      {
        "id": "rustfmt-fix",
        "description": "Apply Rust formatting",
        "phase": "fix",
        "when": {
          "changed": {
            "paths": ["crates/**/*.rs"]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": ["tend-rustfmt-fix"],
            "file_args": "matched",
            "mutates": true
          }
        }
      },
      {
        "id": "statix-fix",
        "description": "Apply safe Statix fixes",
        "phase": "fix",
        "when": {
          "changed": {
            "paths": ["*.nix", "modules/**/*.nix"]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": ["tend-statix-fix"],
            "file_args": "matched",
            "mutates": true
          }
        }
      },
      {
        "id": "nixfmt-fix",
        "description": "Apply Nix formatting",
        "phase": "fix",
        "when": {
          "changed": {
            "paths": ["*.nix", "modules/**/*.nix"]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": ["tend-nixfmt-fix"],
            "file_args": "matched",
            "mutates": true
          }
        }
      }
    ]
  }
}
